diff --git a/hypr/hypridle.conf b/hypr/hypridle.conf
new file mode 100644
index 0000000..ab38768
--- /dev/null
+++ b/hypr/hypridle.conf
@@ -0,0 +1,21 @@
+# ⸸ hypridle — idle management ⸸
+# System suspend is disabled in configuration.nix; this only locks + blanks.
+
+general {
+    lock_cmd = pidof hyprlock || hyprlock       # never spawn a second instance
+    before_sleep_cmd = loginctl lock-session
+    after_sleep_cmd = hyprctl dispatch dpms on
+}
+
+# Lock after 10 minutes idle
+listener {
+    timeout = 600
+    on-timeout = loginctl lock-session
+}
+
+# Screens off after 15 minutes
+listener {
+    timeout = 900
+    on-timeout = hyprctl dispatch dpms off
+    on-resume = hyprctl dispatch dpms on
+}
