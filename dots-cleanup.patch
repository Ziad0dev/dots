index 0000000..aaadd8d
--- /dev/null
+++ b/hypr/hyprlock.conf
@@ -0,0 +1,44 @@
+# ⸸ hyprlock — occult blood red ⸸
+
+general {
+    hide_cursor = true
+    grace = 5
+}
+
+background {
